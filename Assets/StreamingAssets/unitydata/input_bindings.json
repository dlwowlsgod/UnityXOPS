{
    "actions": [
        {
            "name": "look",
            "type": "PassThrough",
            "bindings": ["<Mouse>/delta"],
            "composites": [
                {
                    "type": "2DVector",
                    "up": "<Keyboard>/upArrow",
                    "down": "<Keyboard>/downArrow",
                    "left": "<Keyboard>/leftArrow",
                    "right": "<Keyboard>/rightArrow"
                }
            ]
        },
        {
            "name": "move",
            "type": "Value",
            "composites": [
                {
                    "type": "2DVector",
                    "up": "<Keyboard>/w",
                    "down": "<Keyboard>/s",
                    "left": "<Keyboard>/a",
                    "right": "<Keyboard>/d"
                }
            ]
        },
        { "name": "jump",     "type": "Button", "bindings": ["<Keyboard>/space"] },
        { "name": "walk",     "type": "Button", "bindings": ["<Keyboard>/leftShift"] },
        { "name": "drop",     "type": "Button", "bindings": ["<Keyboard>/g"] },
        { "name": "fire",     "type": "Button", "bindings": ["<Mouse>/leftButton"] },
        { "name": "zoom",     "type": "Button", "bindings": ["<Mouse>/rightButton"] },
        { "name": "previous", "type": "Button", "bindings": ["<Keyboard>/z"] },
        { "name": "next",     "type": "Button", "bindings": ["<Keyboard>/x"] },
        { "name": "reload",   "type": "Button", "bindings": ["<Keyboard>/r"] },
        { "name": "first",    "type": "Button", "bindings": ["<Keyboard>/1"] },
        { "name": "second",   "type": "Button", "bindings": ["<Keyboard>/2"] },
        { "name": "interact", "type": "Button", "bindings": ["<Keyboard>/F"] },
        { "name": "escape",   "type": "Button", "bindings": ["<Keyboard>/escape"] }
    ]
}
